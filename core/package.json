{
  "name": "@eventengine/core",
  "version": "0.0.0",
  "type": "module",
  "description": "event-engine foundation: define events, build the Event envelope, and drive the emit → dispatch → handlers spine.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DYB-Development/event-engine.git",
    "directory": "core"
  },
  "homepage": "https://github.com/DYB-Development/event-engine/tree/main/core#readme",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "the-local/agents"],
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "pnpm build",
    "build:locals": "the-local build ."
  },
  "dependencies": {
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "the-local": {
    "prefix": "core",
    "scope": "event definitions and the emit → dispatch → handlers spine",
    "agentsDir": "the-local/agents"
  }
}
